---
# Configuration pour clangd

# IntelliSense
InlayHints:
  Enabled: true
  ParameterNames: true
  DeducedTypes: true

# Contrôle du compilateur
CompileFlags:
  # Drapeaux de compilation supplémentaires
  Add: 
    - "-std=c++17"
    - "-Wall"
    - "-Wextra"
    - "-Wpedantic"
    - "-O0"
    - "-g"
    - "-I${workspaceFolder}/include"
  # Database de compilation
  CompilationDatabase: "build"

# Chemins d'include
Index:
  # Répertoires à indexer pour la recherche de symboles
  Background: Build

# Diagnostics (erreurs/avertissements)
Diagnostics:
  # Activer les diagnostics
  ClangTidy:
    Add:
      - "modernize-*"
      - "readability-*"
      - "performance-*"
    Remove:
      - "modernize-use-trailing-return-type"
      - "readability-magic-numbers"

# Assistant de code
Hover:
  ShowAKA: true

# Completion
Completion:
  AllScopes: true