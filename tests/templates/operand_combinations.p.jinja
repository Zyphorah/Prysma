{% for op in combinations %}
fn bool test_{{ op.id }}() {
    dec {{ type_name }} l = {{ op.left }};
    dec {{ type_name }} r = {{ op.right }};
    dec {{ type_name }} res = l {{ op.op }} r;
    if (res != {{ op.exp }}) {
        return false;
    }
    return true;
}

{% endfor %}

fn int32 main() {
    dec string[] intro = "==== Operands Combinations ({{ type_name }} / {{ op_group_name }}) ====";
    call print(ref intro); call backSlashN();

    {% for op in combinations %}
    if (call test_{{ op.id }}() == false) {
        dec string[] failMsg_{{ loop.index }} = "FAIL: {{ op.id }}";
        call print(ref failMsg_{{ loop.index }}); call backSlashN();
        return 1;
    }
    {% endfor %}

    dec string[] success = "==== SUCCESS ====";
    call print(ref success); call backSlashN();
    return 0;
}