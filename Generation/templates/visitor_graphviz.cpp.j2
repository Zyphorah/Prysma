#include "Compiler/Visitor/ASTGraphViz/GeneralVisitorGraphViz.h"
#include "Compiler/VisualGraph/OutputVisualGraphText.h"
#include "Compiler/Visitor/VisitorBaseGenerale.h"
#include "Compiler/AST/AST_Genere.h"
#include "Compiler/AST/Nodes/NodeInstruction.h"

GeneralVisitorGraphViz::GeneralVisitorGraphViz(OutputVisualGraphText outputVisualGraph)
    : _outputVisualGraph(std::move(outputVisualGraph))
{}

GeneralVisitorGraphViz::~GeneralVisitorGraphViz()
{}

void GeneralVisitorGraphViz::generate()
{
    _outputVisualGraph.generate();
}

{% for nom, label, traversables in methodes %}
void GeneralVisitorGraphViz::visiter(Node{{ nom }}* node)
{
    (void)node;
    int idNode = _outputVisualGraph.addNode({{ label }});
{% for getter, type_champ in traversables %}
{% if type_champ == 'std::vector<INode*>' %}
    for (auto* element : node->{{ getter }}())
    {
        element->accept(this);
        int idChild = _pileIds.top();
        _pileIds.pop();
        _outputVisualGraph.addEdge(idNode, idChild);
    }
{% else %}
    if (node->{{ getter }}() != nullptr)
    {
        node->{{ getter }}()->accept(this);
        int idChild = _pileIds.top();
        _pileIds.pop();
        _outputVisualGraph.addEdge(idNode, idChild);
    }
{% endif %}
{% endfor %}
    _pileIds.push(idNode);
}
{% endfor %}
void GeneralVisitorGraphViz::visiter(NodeInstruction* node)
{
    int idNode = _outputVisualGraph.addNode("Instruction");

    for (INode* child : node->getChildren())
    {
        child->accept(this);
        int idChild = _pileIds.top();
        _pileIds.pop();
        _outputVisualGraph.addEdge(idNode, idChild);
    }
    _pileIds.push(idNode);
}
