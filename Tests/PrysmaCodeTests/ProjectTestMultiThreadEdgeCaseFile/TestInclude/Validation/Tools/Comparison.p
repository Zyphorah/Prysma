fn bool estEgalInt(arg int32 a, arg int32 b)
{
    if (a == b) {
        return true;
    }
    return false;
}

fn bool estPlusGrandInt(arg int32 a, arg int32 b)
{
    if (a > b) {
        return true;
    }
    return false;
}

fn bool estPlusPetitInt(arg int32 a, arg int32 b)
{
    if (a < b) {
        return true;
    }
    return false;
}

