fn bool isEqualInt(arg int32 a, arg int32 b)
{
    if (a == b) {
        return true;
    }
    return false;
}

fn bool isGreaterInt(arg int32 a, arg int32 b)
{
    if (a > b) {
        return true;
    }
    return false;
}

fn bool isLessInt(arg int32 a, arg int32 b)
{
    if (a < b) {
        return true;
    }
    return false;
}

